# Better Auth — GitHub OAuth
# GitHub callback URL: http://localhost:3000/api/auth/callback/github
BETTER_AUTH_URL=http://localhost:3000
# Generate a long random string for the secret, e.g. using `openssl rand -hex 32`
BETTER_AUTH_SECRET=replace_with_a_long_random_secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

AI_GATEWAY_API_KEY=your_api_key_here

# Neon Postgres — run history persistence
DATABASE_URL=postgres://postgres:postgres@localhost:5432/llm_battle

# Tigris S3 — screenshot and model artifact storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=
AWS_ENDPOINT_URL_IAM=
AWS_REGION=
TIGRIS_BUCKET=llm-battle
